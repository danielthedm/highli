{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node", "react"],
    "typeRoots": ["./node_modules/@types", "../node_modules/@types"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
