# AI Provider
AI_PROVIDER=anthropic          # "anthropic" or "openai"
AI_MODEL=claude-sonnet-4-20250514  # or "gpt-4o", etc.

# AI API Keys (provide the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Data Sources (all optional — highli works with whatever you connect)
GITHUB_TOKEN=
SLACK_TOKEN=
LINEAR_API_KEY=
NOTION_TOKEN=

# Jira (Atlassian Cloud)
JIRA_TOKEN=
JIRA_EMAIL=
JIRA_BASE_URL=              # e.g. https://yourorg.atlassian.net

# Confluence (Atlassian Cloud)
CONFLUENCE_TOKEN=
CONFLUENCE_EMAIL=
CONFLUENCE_BASE_URL=        # e.g. https://yourorg.atlassian.net

# GitLab
GITLAB_TOKEN=
GITLAB_URL=                 # optional, defaults to https://gitlab.com

# Bitbucket
BITBUCKET_TOKEN=            # app password
BITBUCKET_USERNAME=
BITBUCKET_WORKSPACE=

# Asana
ASANA_TOKEN=

# Google Docs (OAuth access token)
GOOGLE_TOKEN=

# PagerDuty
PAGERDUTY_TOKEN=

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=               # optional, defaults to datadoghq.com
