{
  "name": "highli-monorepo",
  "version": "0.2.0",
  "description": "Bottoms-up engineering experience platform — solo CLI, web app, and self-hosted server.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielthedm/highli.git"
  },
  "workspaces": [
    "cli",
    "core",
    "sources",
    "web"
  ],
  "scripts": {
    "highli": "tsx cli/src/index.tsx",
    "dev": "tsx cli/src/index.tsx",
    "build": "npm -w highli run build",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
